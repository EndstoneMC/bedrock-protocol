{% set members = enum | enum_members %}
{% set csince = enum | class_since %}
{% set change_points = enum | enum_change_points %}
{% if change_points %}
{% for cp, entries in change_points %}
namespace v{{ cp }} {
enum {{ enum.name }} : int {
{% for name, value in entries %}
    {{ name | camelize }} = {{ value }},
{% endfor %}
};
}  // namespace v{{ cp }}
{% if not loop.last %}

{% endif %}
{% endfor %}

namespace details {
template <int ProtocolVersion>
struct {{ enum.name }}At;
{% for cp, _entries in change_points %}
template <int ProtocolVersion> requires (ProtocolVersion >= {{ cp }}{% if not loop.last %} && ProtocolVersion < {{ change_points[loop.index][0] }}{% endif %})
struct {{ enum.name }}At<ProtocolVersion> { using type = v{{ cp }}::{{ enum.name }}; };
{% endfor %}
}  // namespace details

template <int ProtocolVersion>
using {{ enum.name }}_ = typename details::{{ enum.name }}At<ProtocolVersion>::type;
{% else %}
enum {{ enum.name }} : int {
{% for name, value in members.always %}
    {{ name | camelize }} = {{ value }},
{% endfor %}
};

template <int ProtocolVersion>
using {{ enum.name }}_ = {{ enum.name }};
{% endif %}
