{% set f = cls | class_fields %}
{% if f is none %}
struct {{ cls.name }} {
};
{% elif f.specializations %}
template <int ProtocolVersion>
struct {{ cls.name }}_;
{% for lo, hi, visible in f.specializations %}

template <int ProtocolVersion> requires ({% if lo is not none %}ProtocolVersion >= {{ lo }}{% endif %}{% if lo is not none and hi is not none %} && {% endif %}{% if hi is not none %}ProtocolVersion < {{ hi }}{% endif %})
struct {{ cls.name }}_<ProtocolVersion> {
{% for name, type, value in f.constants %}
    static constexpr {{ type }} {{ name }} = {{ value }};
{% endfor %}
{% for field in visible %}
    {{ field.ctype }} {{ field.name }};
{% endfor %}
};
{% endfor %}
{% else %}
struct {{ cls.name }} {
{% for name, type, value in f.constants %}
    static constexpr {{ type }} {{ name }} = {{ value }};
{% endfor %}
{% for field in f.fields %}
    {{ field.ctype }} {{ field.name }};
{% endfor %}
};
{% endif %}
